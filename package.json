{
  "name": "agentic-ai-desktop",
  "version": "1.0.0",
  "description": "Agentic AI — Desktop Demo",
  "main": "main.js",
  "scripts": {
    "start":        "electron .",
    "build:win":    "electron-builder --win --publish never",
    "build:mac":    "electron-builder --mac --publish never",
    "release:win":  "electron-builder --win --publish always",
    "release:mac":  "electron-builder --mac --publish always"
  },
  "build": {
    "appId":       "nl.infogroen.agentic-ai-desktop",
    "productName": "Agentic AI",
    "copyright":   "© 2026 Infogroen",
    "publish": {
      "provider": "github",
      "owner":    "steenkzz",
      "repo":     "agentic-ai-desktop"
    },
    "directories": { "output": "dist" },
    "files": ["main.js", "renderer/**/*", "assets/**/*"],
    "win": {
      "target": "nsis",
      "icon":   "assets/icon.ico"
    },
    "mac": {
      "target":   "dmg",
      "icon":     "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
